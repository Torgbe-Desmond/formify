{
  "Storage": {
    "Provider": "MongoDB",
    "LocalRootPath": "uploads",
    "MongoDB": {
      "DatabaseName": "Formify",
      "CollectionName": "fileContents"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    }
  },
  "Jwt": {
    "Issuer": "FastTransfers",
    "Audience": "FastTransfers",
    "ExpiryMinutes": 60
  }
}